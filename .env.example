# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Database (matches docker-compose.yml defaults)
DB_URL=jdbc:postgresql://localhost:5432/user_registration
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — must be at least 32 characters
JWT_SECRET=change-me-to-something-long-and-random-in-production

# Email (Gmail example — use an App Password, not your real password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com

# App
APP_BASE_URL=http://localhost:8080

# CAPTCHA — set to false to skip verification locally
# Get real keys at: https://www.google.com/recaptcha/admin
CAPTCHA_ENABLED=false
CAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
